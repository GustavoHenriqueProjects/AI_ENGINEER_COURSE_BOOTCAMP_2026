# Copie para .env e preencha o que precisar.

# RAG: embeddings (padrão no código: BAAI/bge-m3). Pouca RAM: multilingual-e5-small ou e5-base.
# Ao trocar, apague a pasta do Chroma (ex.: db/ ou o que for CHROMA_PERSIST_DIR) e rode python build_rag.py.
# EMBEDDING_MODEL=BAAI/bge-m3
# Base estruturada (blocos com cabeçalho TIPO= | SECAO= | …)
# RAG_KNOWLEDGE_FILE=txt/manual_brain4care.txt
# Chaves de metadados no Chroma: pt (tipo, pais, …) ou en (type, country, …). Reindexar após mudar.
# RAG_METADATA_KEY_LANG=pt
# Recuperação /rag: top-k no Chroma; truncagem opcional por trecho (0 = texto completo)
# RAG_K=4
# RAG_CONTEXT_MAX_CHARS=0
# Temperatura Ollama no /rag (0.0–0.3 recomendado para respostas alinhadas ao manual; padrão 0.2)
# RAG_TEMPERATURE=0.2

# Ollama (local)
# OLLAMA_CHAT_URL=http://localhost:11434/api/chat

# OpenAI — necessário só para modelos gpt-* / o1-* / o3-* / chatgpt-* / ft:gpt-...
# OPENAI_API_KEY=

# Google Gemini — se definido, o app oferece uma opção “Gemini (automático)”
# e usa sempre o modelo abaixo (o usuário não escolhe a variante).
# GOOGLE_API_KEY=
# (ou)
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# (opcional) URLs customizadas
# OPENAI_API_BASE=https://api.openai.com/v1
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
